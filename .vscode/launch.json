{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Front-end Streamlit",
            "type": "node-terminal",
            "request": "launch",
            "command": "streamlit run src/frontend/main_page.py",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src/frontend"
            }
        },
        {
            "name": "Back-end FastApi",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/backend/app.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src/backend"
            }
        }
    ]
}